#!/usr/bin/env bash
# commit-msg: enforce conventional commit format
COMMIT_MSG=$(cat "$1")

# Pass through git-generated messages
[[ "$COMMIT_MSG" =~ ^(Merge|Revert|fixup!|squash!) ]] && exit 0

FIRST_LINE=$(echo "$COMMIT_MSG" | head -1)
VALID="^(feat|fix|docs|perf|refactor|chore|test|style|ci)(\(.+\))?: .{5,}"

if ! [[ "$FIRST_LINE" =~ $VALID ]]; then
  echo "Bad commit message: '$FIRST_LINE'"
  echo "Format: type(scope): description   (min 5 chars after colon)"
  echo "Types:  feat fix docs perf refactor chore test style ci"
  exit 1
fi

exit 0
