#!/usr/bin/env bash
# pre-commit: format and vet staged Go files only
set -e

[ -n "${GIT_SKIP_HOOKS}" ] && exit 0

STAGED_GO=$(git diff --cached --name-only | grep '\.go$' || true)
[ -z "$STAGED_GO" ] && exit 0

echo "Running go fmt..."
go fmt ./...
git add $(git diff --cached --name-only | grep '\.go$' || true)

echo "Running go vet..."
go vet ./...

exit 0
