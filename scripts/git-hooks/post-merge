#!/usr/bin/env bash
# post-merge: tidy deps and sync hooks after a merge into main
CHANGED=$(git diff --name-only HEAD@{1} HEAD 2>/dev/null || true)

# Sync hooks if they changed in this merge
if echo "$CHANGED" | grep -q "scripts/git-hooks/"; then
  echo "Hooks changed — syncing .git/hooks/..."
  bash "$(git rev-parse --show-toplevel)/scripts/install-hooks.sh"
fi

# Tidy go modules if deps changed
if echo "$CHANGED" | grep -qE "go\.(mod|sum)"; then
  echo "Dependencies changed — running go mod tidy..."
  go mod tidy
fi

exit 0
