#!/usr/bin/env bash
# pre-push: run QA tests before any push that touches main
set -e

[ "${GIT_SKIP_HOOKS}" = "1" ] && exit 0

REMOTE="$1"
REMOTE_URL="$2"

while read LOCAL_REF LOCAL_SHA REMOTE_REF REMOTE_SHA; do
  BRANCH="${REMOTE_REF#refs/heads/}"

  # Only gate pushes that land on main
  [ "$BRANCH" != "main" ] && continue

  # Reject direct pushes from non-feature branches
  CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)
  if [ "$CURRENT_BRANCH" = "main" ]; then
    echo "Direct push to main is not allowed."
    echo "Create a feature branch: git checkout -b feat/your-feature"
    echo "Then push it and merge via: scripts/merge-to-main.sh"
    echo "Bypass: GIT_SKIP_HOOKS=1 git push"
    exit 1
  fi

  echo "Running QA tests before push to main..."
  if ! go test ./... -count=1 -timeout 120s; then
    echo "Tests failed. Push to main blocked."
    exit 1
  fi

  echo "QA passed — pushing to main."
done

exit 0
